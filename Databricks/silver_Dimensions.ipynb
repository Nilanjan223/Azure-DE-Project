# Databricks notebook source
import os 
import sys

print(sys.path)

# COMMAND ----------

from pyspark.sql.functions import *
from pyspark.sql.types import *
from pyspark.sql.window import Window

# COMMAND ----------

from transformations import reusable

# COMMAND ----------

# MAGIC %md
# MAGIC ## **DimUser**

# COMMAND ----------

# MAGIC %md
# MAGIC #### **AUTOLOADER**

# COMMAND ----------

df_user = spark.readStream.format("cloudFiles")\
            .option("cloudFiles.format","parquet")\
            .option("cloudFiles.schemaLocation","abfss://silver@azurestoragenv.dfs.core.windows.net/DimUser/checkpoint")\
            .option("schemaEvolutionMode","addNewColumns")\
            .load("abfss://bronze@azurestoragenv.dfs.core.windows.net/DimUser")


# COMMAND ----------

# display(df_user,checkpointLocation="abfss://silver@azurestoragenv.dfs.core.windows.net/DimUser/checkpoint")

# COMMAND ----------

df_user = df_user.withColumn("user_name",upper(col("user_name")))


# COMMAND ----------

# display(df_user,checkpointLocation="abfss://silver@azurestoragenv.dfs.core.windows.net/DimUser/checkpoint/temp/")

# COMMAND ----------

df_user_obj = reusable()

df_user = df_user_obj.dropcol(df_user,['_rescued_data'])
df_user = df_user.dropDuplicates(['user_id'])

# COMMAND ----------

df_user.writeStream.format("delta")\
            .outputMode("append")\
            .option("checkpointLocation","abfss://silver@azurestoragenv.dfs.core.windows.net/DimUser/checkpoint")\
            .trigger(once=True)\
            .option("path","abfss://silver@azurestoragenv.dfs.core.windows.net/DimUser/data")\
            .toTable("spotify_catalog.silver.DimUser")

# COMMAND ----------

# MAGIC %md
# MAGIC ## **DimArtist**

